# App
NODE_ENV=development
PORT=3000

# Database (PostgreSQL + PostGIS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gpsmonitor
DB_USER=gpsuser
DB_PASSWORD=gpspassword

# Redis
REDIS_URL=redis://localhost:6379

# JWT — MUST be at least 32 characters
JWT_SECRET=change-me-to-a-random-string-min-32-chars
JWT_EXPIRES_IN=15m

# Refresh Token — MUST be at least 32 characters (different from JWT_SECRET)
REFRESH_TOKEN_SECRET=change-me-to-another-random-string-min-32
REFRESH_TOKEN_EXPIRES_IN=7d

# Email (Ethereal — leave empty to auto-generate in development)
# In production, replace with real SMTP credentials
ETHEREAL_USER=
ETHEREAL_PASS=
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=noreply@gpsmonitor.com
