# App
NODE_ENV=development
PORT=3000

# Database (PostgreSQL + PostGIS)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=gpsmonitor
DB_USER=gpsuser
DB_PASSWORD=gpspassword

# Redis
REDIS_URL=redis://localhost:6379

# JWT — MUST be at least 32 characters
JWT_SECRET=change-me-at-least-32-characters!!
JWT_EXPIRES_IN=15m

# Refresh Token
REFRESH_TOKEN_SECRET=change-me-refresh-at-least-32-chars!!
REFRESH_TOKEN_EXPIRES_IN=7d

# Email
ETHEREAL_USER=
ETHEREAL_PASS=
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=noreply@gpsmonitor.com

# CORS
CORS_ORIGIN=http://localhost:4200

# GPS Tracking
DEVIATION_THRESHOLD_METERS=50
SOCKET_CORS_ORIGIN=http://localhost:4200
